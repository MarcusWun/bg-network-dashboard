{
  "__inputs": [
    {
      "description": "InfluxDB 2.x datasource using Flux query language",
      "label": "InfluxDB",
      "name": "DS_INFLUXDB",
      "pluginId": "influxdb",
      "pluginName": "InfluxDB",
      "type": "datasource"
    },
    {
      "description": "Signal K REST API via JSON API datasource plugin",
      "label": "SignalK",
      "name": "DS_SIGNALK",
      "pluginId": "marcusolsson-json-datasource",
      "pluginName": "JSON API",
      "type": "datasource"
    }
  ],
  "__requires": [
    {
      "id": "grafana",
      "name": "Grafana",
      "type": "grafana",
      "version": "10.0.0"
    },
    {
      "id": "influxdb",
      "name": "InfluxDB",
      "type": "datasource",
      "version": "1.0.0"
    },
    {
      "id": "marcusolsson-json-datasource",
      "name": "JSON API",
      "type": "datasource",
      "version": "1.0.0"
    },
    {
      "id": "stat",
      "name": "Stat",
      "type": "panel",
      "version": ""
    },
    {
      "id": "table",
      "name": "Table",
      "type": "panel",
      "version": ""
    },
    {
      "id": "timeseries",
      "name": "Time series",
      "type": "panel",
      "version": ""
    },
    {
      "id": "bargauge",
      "name": "Bar gauge",
      "type": "panel",
      "version": ""
    }
  ],
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": { "type": "grafana", "uid": "-- Grafana --" },
        "enable": true,
        "hide": true,
        "iconColor": "rgba(0, 211, 255, 1)",
        "name": "Annotations & Alerts",
        "type": "dashboard"
      }
    ]
  },
  "description": "Live diagnostics for the NMEA 2000 CAN bus — device discovery, PGN traffic, message rates, AIS targets, and bus load.",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "id": 1,
      "title": "Network Health Summary",
      "type": "row"
    },
    {
      "datasource": { "type": "influxdb", "uid": "${DS_INFLUXDB}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "green", "value": 1 }
            ]
          },
          "unit": "short"
        },
        "overrides": []
      },
      "gridPos": { "h": 5, "w": 6, "x": 0, "y": 1 },
      "id": 2,
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "center",
        "orientation": "auto",
        "reduceOptions": {
          "calcs": ["lastNotNull"],
          "fields": "",
          "values": false
        },
        "textMode": "auto"
      },
      "title": "Total PGNs",
      "description": "Unique PGN numbers seen on the bus in the last 30 seconds",
      "targets": [
        {
          "datasource": { "type": "influxdb", "uid": "${DS_INFLUXDB}" },
          "query": "from(bucket: \"signalk\")\n  |> range(start: -30s)\n  |> filter(fn: (r) => exists r.pgn)\n  |> keep(columns: [\"pgn\"])\n  |> distinct(column: \"pgn\")\n  |> count()\n  |> map(fn: (r) => ({_value: float(v: r._value), _time: now()}))",
          "refId": "A"
        }
      ],
      "type": "stat"
    },
    {
      "datasource": { "type": "influxdb", "uid": "${DS_INFLUXDB}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 1 },
              { "color": "green", "value": 5 }
            ]
          },
          "unit": "short"
        },
        "overrides": []
      },
      "gridPos": { "h": 5, "w": 6, "x": 6, "y": 1 },
      "id": 3,
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "center",
        "orientation": "auto",
        "reduceOptions": {
          "calcs": ["lastNotNull"],
          "fields": "",
          "values": false
        },
        "textMode": "auto"
      },
      "title": "Active Sources",
      "description": "Unique N2K source addresses seen in the last 30 seconds",
      "targets": [
        {
          "datasource": { "type": "influxdb", "uid": "${DS_INFLUXDB}" },
          "query": "from(bucket: \"signalk\")\n  |> range(start: -30s)\n  |> filter(fn: (r) => exists r.source)\n  |> keep(columns: [\"source\"])\n  |> distinct(column: \"source\")\n  |> count()\n  |> map(fn: (r) => ({_value: float(v: r._value), _time: now()}))",
          "refId": "A"
        }
      ],
      "type": "stat"
    },
    {
      "datasource": { "type": "influxdb", "uid": "${DS_INFLUXDB}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 10 },
              { "color": "green", "value": 50 }
            ]
          },
          "unit": "reqps",
          "decimals": 1
        },
        "overrides": []
      },
      "gridPos": { "h": 5, "w": 6, "x": 12, "y": 1 },
      "id": 4,
      "options": {
        "colorMode": "background",
        "graphMode": "area",
        "justifyMode": "center",
        "orientation": "auto",
        "reduceOptions": {
          "calcs": ["lastNotNull"],
          "fields": "",
          "values": false
        },
        "textMode": "auto"
      },
      "title": "Bus Message Rate",
      "description": "Total N2K messages per second across all sources (last 10 seconds)",
      "targets": [
        {
          "datasource": { "type": "influxdb", "uid": "${DS_INFLUXDB}" },
          "query": "from(bucket: \"signalk\")\n  |> range(start: -10s)\n  |> group()\n  |> count()\n  |> map(fn: (r) => ({_value: float(v: r._value) / 10.0, _time: now()}))",
          "refId": "A"
        }
      ],
      "type": "stat"
    },
    {
      "datasource": { "type": "influxdb", "uid": "${DS_INFLUXDB}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 1 },
              { "color": "red", "value": 6 }
            ]
          },
          "unit": "short"
        },
        "overrides": []
      },
      "gridPos": { "h": 5, "w": 6, "x": 18, "y": 1 },
      "id": 5,
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "center",
        "orientation": "auto",
        "reduceOptions": {
          "calcs": ["lastNotNull"],
          "fields": "",
          "values": false
        },
        "textMode": "auto"
      },
      "title": "Error Count",
      "description": "N2K parse errors in the last 60 seconds",
      "targets": [
        {
          "datasource": { "type": "influxdb", "uid": "${DS_INFLUXDB}" },
          "query": "from(bucket: \"signalk\")\n  |> range(start: -60s)\n  |> filter(fn: (r) => r[\"_measurement\"] == \"signalk.errors\" or r[\"_field\"] == \"parseError\" or r[\"_measurement\"] =~ /error/)\n  |> group()\n  |> count()\n  |> map(fn: (r) => ({_value: float(v: r._value), _time: now()}))",
          "refId": "A"
        }
      ],
      "type": "stat"
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 6 },
      "id": 10,
      "title": "Live PGN Table",
      "type": "row"
    },
    {
      "datasource": { "type": "influxdb", "uid": "${DS_INFLUXDB}" },
      "fieldConfig": {
        "defaults": {
          "custom": {
            "align": "auto",
            "cellOptions": { "type": "auto" },
            "filterable": true,
            "inspect": false
          },
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [{ "color": "green", "value": null }]
          }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "pgn" },
            "properties": [
              { "id": "displayName", "value": "PGN" },
              { "id": "custom.width", "value": 100 }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "pgnName" },
            "properties": [
              { "id": "displayName", "value": "Name" },
              { "id": "custom.width", "value": 240 }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "source" },
            "properties": [
              { "id": "displayName", "value": "Source Address" },
              { "id": "custom.width", "value": 120 }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "deviceName" },
            "properties": [
              { "id": "displayName", "value": "Device Name" },
              { "id": "custom.width", "value": 200 }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "rate" },
            "properties": [
              { "id": "displayName", "value": "Rate (Hz)" },
              { "id": "unit", "value": "hertz" },
              { "id": "decimals", "value": 2 },
              { "id": "custom.width", "value": 90 }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "_value" },
            "properties": [
              { "id": "displayName", "value": "Last Value" }
            ]
          }
        ]
      },
      "gridPos": { "h": 10, "w": 24, "x": 0, "y": 7 },
      "id": 11,
      "options": {
        "cellHeight": "sm",
        "footer": {
          "countRows": false,
          "enablePagination": true,
          "fields": "",
          "reducer": ["sum"],
          "show": false
        },
        "showHeader": true,
        "sortBy": [{ "desc": false, "displayName": "PGN" }]
      },
      "title": "Live PGN Table — All Active PGNs",
      "description": "Every PGN currently active on the N2K bus. Auto-discovered — no predetermined list. Use the column filter to search by PGN or name.",
      "transformations": [
        {
          "id": "groupBy",
          "options": {
            "fields": {
              "pgn":        { "aggregations": [], "operation": "groupby" },
              "source":     { "aggregations": [], "operation": "groupby" },
              "_value":     { "aggregations": ["last"], "operation": "aggregate" },
              "_time":      { "aggregations": ["last"], "operation": "aggregate" },
              "msgCount":   { "aggregations": ["sum"], "operation": "aggregate" }
            }
          }
        },
        {
          "id": "addField",
          "options": {
            "alias": "rate",
            "binary": {
              "left": "msgCount (sum)",
              "operator": "/",
              "right": "60"
            },
            "mode": "binaryOperation"
          }
        },
        {
          "id": "organize",
          "options": {
            "excludeByName": { "msgCount (sum)": true },
            "renameByName": {
              "_value (last)": "Last Value",
              "_time (last)": "Last Seen"
            }
          }
        }
      ],
      "targets": [
        {
          "datasource": { "type": "influxdb", "uid": "${DS_INFLUXDB}" },
          "query": "from(bucket: \"signalk\")\n  |> range(start: -60s)\n  |> filter(fn: (r) => exists r.pgn)\n  |> group(columns: [\"pgn\", \"source\"])\n  |> map(fn: (r) => ({r with msgCount: 1}))\n  |> reduce(\n      fn: (r, accumulator) => ({msgCount: accumulator.msgCount + 1, _value: r._value, _time: r._time}),\n      identity: {msgCount: 0, _value: 0.0, _time: 1970-01-01T00:00:00Z}\n    )\n  |> map(fn: (r) => ({r with rate: float(v: r.msgCount) / 60.0}))",
          "refId": "A"
        }
      ],
      "type": "table"
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 17 },
      "id": 20,
      "repeat": "source",
      "repeatDirection": "v",
      "title": "Device: $source",
      "type": "row"
    },
    {
      "datasource": { "type": "influxdb", "uid": "${DS_INFLUXDB}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "mappings": [
            { "options": { "from": 0, "result": { "color": "green", "text": "Online" }, "to": 5 }, "type": "range" },
            { "options": { "from": 5, "result": { "color": "yellow", "text": "Stale (5-30s)" }, "to": 30 }, "type": "range" },
            { "options": { "from": 30, "result": { "color": "red", "text": "Offline (>30s)" }, "to": 9999 }, "type": "range" }
          ],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 5 },
              { "color": "red", "value": 30 }
            ]
          },
          "unit": "s"
        },
        "overrides": []
      },
      "gridPos": { "h": 3, "w": 6, "x": 0, "y": 18 },
      "id": 21,
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "center",
        "orientation": "auto",
        "reduceOptions": {
          "calcs": ["lastNotNull"],
          "fields": "",
          "values": false
        },
        "textMode": "auto"
      },
      "repeat": "source",
      "repeatDirection": "h",
      "title": "Status — Source $source",
      "description": "Seconds since last message from this source. Green <5s, Yellow 5-30s, Red >30s",
      "targets": [
        {
          "datasource": { "type": "influxdb", "uid": "${DS_INFLUXDB}" },
          "query": "import \"date\"\n\nfrom(bucket: \"signalk\")\n  |> range(start: -5m)\n  |> filter(fn: (r) => r.source == \"${source}\")\n  |> last()\n  |> map(fn: (r) => ({_value: float(v: uint(v: date.sub(from: r._time, d: duration(v: uint(v: now()) - uint(v: r._time)))) / 1000000000), _time: now()}))",
          "refId": "A"
        }
      ],
      "type": "stat"
    },
    {
      "datasource": { "type": "influxdb", "uid": "${DS_INFLUXDB}" },
      "fieldConfig": {
        "defaults": {
          "custom": {
            "align": "auto",
            "cellOptions": { "type": "auto" },
            "filterable": true,
            "inspect": false
          },
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [{ "color": "green", "value": null }]
          }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "pgn" },
            "properties": [{ "id": "displayName", "value": "PGN" }, { "id": "custom.width", "value": 100 }]
          },
          {
            "matcher": { "id": "byName", "options": "rate" },
            "properties": [{ "id": "displayName", "value": "Rate (Hz)" }, { "id": "unit", "value": "hertz" }, { "id": "decimals", "value": 2 }]
          },
          {
            "matcher": { "id": "byName", "options": "_value" },
            "properties": [{ "id": "displayName", "value": "Last Value" }]
          },
          {
            "matcher": { "id": "byName", "options": "_time" },
            "properties": [{ "id": "displayName", "value": "Last Seen" }, { "id": "unit", "value": "dateTimeAsIso" }]
          }
        ]
      },
      "gridPos": { "h": 8, "w": 18, "x": 6, "y": 18 },
      "id": 22,
      "options": {
        "cellHeight": "sm",
        "footer": { "countRows": true, "enablePagination": false, "show": true, "reducer": ["count"] },
        "showHeader": true,
        "sortBy": [{ "desc": false, "displayName": "PGN" }]
      },
      "repeat": "source",
      "repeatDirection": "h",
      "title": "PGNs — Source $source",
      "description": "All PGNs transmitted by this N2K source address in the last 60 seconds",
      "targets": [
        {
          "datasource": { "type": "influxdb", "uid": "${DS_INFLUXDB}" },
          "query": "from(bucket: \"signalk\")\n  |> range(start: -60s)\n  |> filter(fn: (r) => r.source == \"${source}\" and exists r.pgn)\n  |> group(columns: [\"pgn\"])\n  |> reduce(\n      fn: (r, accumulator) => ({msgCount: accumulator.msgCount + 1, _value: r._value, _time: r._time}),\n      identity: {msgCount: 0, _value: 0.0, _time: 1970-01-01T00:00:00Z}\n    )\n  |> map(fn: (r) => ({r with rate: float(v: r.msgCount) / 60.0}))",
          "refId": "A"
        }
      ],
      "type": "table"
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 27 },
      "id": 30,
      "title": "AIS Traffic",
      "type": "row"
    },
    {
      "datasource": { "type": "marcusolsson-json-datasource", "uid": "${DS_SIGNALK}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "gray", "value": null },
              { "color": "green", "value": 1 }
            ]
          },
          "unit": "short"
        },
        "overrides": []
      },
      "gridPos": { "h": 5, "w": 6, "x": 0, "y": 28 },
      "id": 31,
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "center",
        "orientation": "auto",
        "reduceOptions": {
          "calcs": ["lastNotNull"],
          "fields": "",
          "values": false
        },
        "textMode": "auto"
      },
      "title": "AIS Targets",
      "description": "Count of unique MMSIs with a position update in the last 5 minutes",
      "targets": [
        {
          "datasource": { "type": "marcusolsson-json-datasource", "uid": "${DS_SIGNALK}" },
          "fields": [{ "jsonPath": "$", "name": "count", "type": "number" }],
          "method": "GET",
          "queryParams": "",
          "refId": "A",
          "urlPath": "/signalk/v1/api/vessels",
          "postData": ""
        }
      ],
      "transformations": [
        {
          "id": "organize",
          "options": {
            "renameByName": { "count": "AIS Targets" }
          }
        }
      ],
      "type": "stat"
    },
    {
      "datasource": { "type": "marcusolsson-json-datasource", "uid": "${DS_SIGNALK}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 0.25 },
              { "color": "green", "value": 0.5 }
            ]
          },
          "unit": "lengthmi",
          "decimals": 2
        },
        "overrides": []
      },
      "gridPos": { "h": 5, "w": 6, "x": 6, "y": 28 },
      "id": 32,
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "center",
        "orientation": "auto",
        "reduceOptions": {
          "calcs": ["min"],
          "fields": "",
          "values": false
        },
        "textMode": "auto"
      },
      "title": "Closest Target",
      "description": "Range in nautical miles to nearest AIS target. Requires own GPS position on bus.",
      "targets": [
        {
          "datasource": { "type": "marcusolsson-json-datasource", "uid": "${DS_SIGNALK}" },
          "fields": [{ "jsonPath": "$[*].navigation.position.value", "name": "position" }],
          "method": "GET",
          "queryParams": "",
          "refId": "A",
          "urlPath": "/signalk/v1/api/vessels"
        }
      ],
      "type": "stat"
    },
    {
      "datasource": { "type": "marcusolsson-json-datasource", "uid": "${DS_SIGNALK}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "fixed", "fixedColor": "blue" },
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [{ "color": "blue", "value": null }]
          },
          "unit": "lengthmi",
          "decimals": 2
        },
        "overrides": []
      },
      "gridPos": { "h": 5, "w": 6, "x": 12, "y": 28 },
      "id": 33,
      "options": {
        "colorMode": "value",
        "graphMode": "none",
        "justifyMode": "center",
        "orientation": "auto",
        "reduceOptions": {
          "calcs": ["max"],
          "fields": "",
          "values": false
        },
        "textMode": "auto"
      },
      "title": "Most Distant Target",
      "description": "Range in nm to farthest AIS target with valid position",
      "targets": [
        {
          "datasource": { "type": "marcusolsson-json-datasource", "uid": "${DS_SIGNALK}" },
          "fields": [{ "jsonPath": "$[*].navigation.position.value", "name": "position" }],
          "method": "GET",
          "queryParams": "",
          "refId": "A",
          "urlPath": "/signalk/v1/api/vessels"
        }
      ],
      "type": "stat"
    },
    {
      "datasource": { "type": "influxdb", "uid": "${DS_INFLUXDB}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "fixed", "fixedColor": "purple" },
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [{ "color": "green", "value": null }]
          },
          "unit": "reqps",
          "decimals": 2
        },
        "overrides": []
      },
      "gridPos": { "h": 5, "w": 6, "x": 18, "y": 28 },
      "id": 34,
      "options": {
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "center",
        "orientation": "auto",
        "reduceOptions": {
          "calcs": ["lastNotNull"],
          "fields": "",
          "values": false
        },
        "textMode": "auto"
      },
      "title": "AIS Update Rate",
      "description": "Total AIS position messages per second (PGN 129038 + 129039)",
      "targets": [
        {
          "datasource": { "type": "influxdb", "uid": "${DS_INFLUXDB}" },
          "query": "from(bucket: \"signalk\")\n  |> range(start: -10s)\n  |> filter(fn: (r) => r.pgn == \"129038\" or r.pgn == \"129039\")\n  |> group()\n  |> count()\n  |> map(fn: (r) => ({_value: float(v: r._value) / 10.0, _time: now()}))",
          "refId": "A"
        }
      ],
      "type": "stat"
    },
    {
      "datasource": { "type": "marcusolsson-json-datasource", "uid": "${DS_SIGNALK}" },
      "fieldConfig": {
